#nexus[ This example demonstrates the dreaded Felsenstein zone. ]begin paup;	cd *;	set storebrlens nostatus autoclose=yes warntree=no notifybeep=no;end;begin taxa;	dimensions ntax=6;	taxlabels A B C D E F;end;begin trees;	tree 1 = [&R] (((A:0.1,B:0.1):0.2,C:0.3):0.1,((D:0.2,E:0.2):0.1,F:0.3):0.1);end;begin dnasim;		simdata nchar=10000;	lset nst=6 rmatrix=(1 2 1 1 3 1) basefreq=(0.2 0.3 0.3 0.2)	     rates=gamma shape=0.5 model=tng;	sitemodels tng:1;	truetree source=memory treenum=1 showtruetree=brlens;	beginsim nreps=1 seed=0 monitor=y;		[ nothing here--we just want the data]	endsim;	set monitor;end;